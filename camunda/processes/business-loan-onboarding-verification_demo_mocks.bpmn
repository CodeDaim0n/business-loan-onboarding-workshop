<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="70fd62a" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.10.0">
  <bpmn:process id="business-loan-onboarding-verification_demo_mocks" name="business-loan-onboarding-verification_demo_mocks" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="v2-demo-mocks" />
    </bpmn:extensionElements>
    <bpmn:serviceTask id="Activity_0e1ermh" name="Analyze company proof" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="openai" target="provider.type" />
          <zeebe:input source="{{secrets.OPENAI_API_KEY}}" target="provider.openai.authentication.apiKey" />
          <zeebe:input source="gpt-5-nano" target="provider.openai.model.model" />
          <zeebe:input source="=&#34;You are a business-document verification assistant. Analyse the uploaded company proof document and extract only information clearly visible in the document. Do not infer, invent, or assume information.&#34; +&#10;&#10;&#34;\n\nAPPLICATION DETAILS&#34; +&#10;&#34;\nRegistered business name: &#34; + get or else(registeredBusinessName, &#34;[not provided]&#34;) +&#10;&#34;\nCompany registration number: &#34; + get or else(companyRegistrationNumber, &#34;[not provided]&#34;) +&#10;&#34;\nRegistered office address: &#34; + get or else(registeredOfficeAddress, &#34;[not provided]&#34;) +&#10;&#34;\nTrading address: &#34; + get or else(tradingAddress, &#34;[not provided]&#34;) +&#10;&#34;\nCompany proof type selected by applicant: &#34; + get or else(companyProofType, &#34;[not provided]&#34;) +&#10;&#34;\nDocument date declared by applicant: &#34; + get or else(companyProofDocDate, &#34;[not provided]&#34;) +&#10;&#10;&#34;\n\nYOUR TASK&#34; +&#10;&#34;\n1. Identify the actual document type.&#34; +&#10;&#34;\n2. Determine whether it matches the selected company proof type.&#34; +&#10;&#34;\n3. Extract, only where visible: business name, company registration number, VAT number, registered address, trading address, document date, and relevant document reference.&#34; +&#10;&#34;\n4. Compare extracted details against the application details above.&#34; +&#10;&#34;\n5. Identify unreadable content, missing information, expired evidence, or discrepancies.&#34; +&#10;&#34;\n6. Do not treat a document as valid evidence if the business name cannot be identified or the document does not reasonably support the selected proof type.&#34; +&#10;&#10;&#34;\n\nDOCUMENT-SPECIFIC RULES&#34; +&#10;&#34;\n- Business bank statement: expect business name and a recent statement date.&#34; +&#10;&#34;\n- VAT registration certificate: expect business name and VAT number.&#34; +&#10;&#34;\n- Certificate of incorporation: expect company name, company number, and incorporation information.&#34; +&#10;&#34;\n- Business utility bill: expect business name or trading name, address, and a recent date.&#34; +&#10;&#34;\n- Latest filed accounts: expect company name, company number, and accounting period.&#34; +&#10;&#34;\n- Business insurance certificate: expect business name, policy date, and insurer or policy reference.&#34; +&#10;&#10;&#34;\n\nRETURN JSON ONLY. Use these exact fields:&#34; +&#10;&#34;\n{&#34; +&#10;&#34;\n  \&#34;document_readable\&#34;: true,&#34; +&#10;&#34;\n  \&#34;document_type_detected\&#34;: null,&#34; +&#10;&#34;\n  \&#34;document_type_matches_selection\&#34;: false,&#34; +&#10;&#34;\n  \&#34;company_name_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;company_number_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;vat_number_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;registered_address_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;trading_address_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;document_date_extracted\&#34;: null,&#34; +&#10;&#34;\n  \&#34;document_reference\&#34;: null,&#34; +&#10;&#34;\n  \&#34;company_name_match\&#34;: false,&#34; +&#10;&#34;\n  \&#34;company_number_match\&#34;: false,&#34; +&#10;&#34;\n  \&#34;registered_address_match\&#34;: false,&#34; +&#10;&#34;\n  \&#34;trading_address_match\&#34;: false,&#34; +&#10;&#34;\n  \&#34;document_recent_enough\&#34;: false,&#34; +&#10;&#34;\n  \&#34;discrepancies\&#34;: [],&#34; +&#10;&#34;\n  \&#34;missing_or_unreadable_fields\&#34;: [],&#34; +&#10;&#34;\n  \&#34;evidence_outcome\&#34;: \&#34;PASS\&#34;,&#34; +&#10;&#34;\n  \&#34;confidence\&#34;: 0.0,&#34; +&#10;&#34;\n  \&#34;summary\&#34;: null&#34; +&#10;&#34;\n}&#34; +&#10;&#10;&#34;\n\nAllowed evidence_outcome values: PASS, INSUFFICIENT_DOCUMENT, DOCUMENT_TYPE_MISMATCH, DATA_MISMATCH, DOCUMENT_EXPIRED, UNREADABLE_DOCUMENT, MANUAL_REVIEW.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Analyse the proof of company&#34;" target="data.userPrompt.prompt" />
          <zeebe:input source="=companyProofDoc[1]" target="data.userPrompt.documents" />
          <zeebe:input source="=agent.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="json" target="data.response.format.type" />
          <zeebe:input source="={&#10;  &#34;type&#34;: &#34;object&#34;,&#10;  &#34;properties&#34;: {&#10;    &#34;document_readable&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;document_type_detected&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;document_type_matches_selection&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;company_name_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;company_number_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;vat_number_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;registered_address_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;trading_address_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;document_date_extracted&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;document_reference&#34;: { &#34;type&#34;: &#34;string&#34; },&#10;    &#34;company_name_match&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;company_number_match&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;registered_address_match&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;trading_address_match&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;document_recent_enough&#34;: { &#34;type&#34;: &#34;boolean&#34; },&#10;    &#34;discrepancies&#34;: {&#10;      &#34;type&#34;: &#34;array&#34;,&#10;      &#34;items&#34;: { &#34;type&#34;: &#34;string&#34; }&#10;    },&#10;    &#34;missing_or_unreadable_fields&#34;: {&#10;      &#34;type&#34;: &#34;array&#34;,&#10;      &#34;items&#34;: { &#34;type&#34;: &#34;string&#34; }&#10;    },&#10;    &#34;evidence_outcome&#34;: {&#10;      &#34;type&#34;: &#34;string&#34;,&#10;      &#34;enum&#34;: [&#10;        &#34;PASS&#34;,&#10;        &#34;INSUFFICIENT_DOCUMENT&#34;,&#10;        &#34;DOCUMENT_TYPE_MISMATCH&#34;,&#10;        &#34;DATA_MISMATCH&#34;,&#10;        &#34;DOCUMENT_EXPIRED&#34;,&#10;        &#34;UNREADABLE_DOCUMENT&#34;,&#10;        &#34;MANUAL_REVIEW&#34;&#10;      ]&#10;    },&#10;    &#34;confidence&#34;: { &#34;type&#34;: &#34;number&#34; },&#10;    &#34;summary&#34;: { &#34;type&#34;: &#34;string&#34; }&#10;  },&#10;  &#34;required&#34;: [&#10;    &#34;document_readable&#34;,&#10;    &#34;document_type_detected&#34;,&#10;    &#34;document_type_matches_selection&#34;,&#10;    &#34;company_name_extracted&#34;,&#10;    &#34;company_number_extracted&#34;,&#10;    &#34;vat_number_extracted&#34;,&#10;    &#34;registered_address_extracted&#34;,&#10;    &#34;trading_address_extracted&#34;,&#10;    &#34;document_date_extracted&#34;,&#10;    &#34;document_reference&#34;,&#10;    &#34;company_name_match&#34;,&#10;    &#34;company_number_match&#34;,&#10;    &#34;registered_address_match&#34;,&#10;    &#34;trading_address_match&#34;,&#10;    &#34;document_recent_enough&#34;,&#10;    &#34;discrepancies&#34;,&#10;    &#34;missing_or_unreadable_fields&#34;,&#10;    &#34;evidence_outcome&#34;,&#10;    &#34;confidence&#34;,&#10;    &#34;summary&#34;&#10;  ]&#10;}" target="data.response.format.schema" />
          <zeebe:input source="Response" target="data.response.format.schemaName" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="resultImageAIAnalysis" />
          <zeebe:header key="resultExpression" value="={&#10;  companyProofAnalyzedByAI: responseJson&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ar89vw</bpmn:incoming>
      <bpmn:outgoing>Flow_0xs7gqs</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1bggnel" name="No verification needed" sourceRef="gateway_verification_needed" targetRef="Event_1dszvoa">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=verificationRoute = "HARD_FAIL"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="gateway_verification_needed" name="Verification needed?">
      <bpmn:incoming>Flow_1rpzhyv</bpmn:incoming>
      <bpmn:incoming>Flow_1colao6</bpmn:incoming>
      <bpmn:outgoing>Flow_10s5gwg</bpmn:outgoing>
      <bpmn:outgoing>Flow_1bggnel</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_1dszvoa" name="Business  loan application completed">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=agent.context.metrics.tokenUsage.inputTokenCount" target="metrics_inputTokenCount" />
          <zeebe:output source="=agent.context.metrics.tokenUsage.outputTokenCount" target="metrics_outputTokenCount" />
          <zeebe:output source="=agent.context.metrics.modelCalls" target="metrics_modelCalls" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0gl7yh5</bpmn:incoming>
      <bpmn:incoming>Flow_1bggnel</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="Activity_0b2aj8s" name="Validate company details [DEMO MOCK]">
      <bpmn:documentation>DEMO MOCK — no Companies House API call is made.

This local Script Task produces an active company-profile response in the same `companyHouseDetails.body` shape used by the rest of the process. It is deliberately deterministic so the workshop can run with no API key.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the Companies House HTTP connector. Preserve the output variable name `companyHouseDetails` and its `body.company_number`, `body.company_status`, `body.company_name`, `body.type`, and `body.registered_office_address` fields.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  &#34;body&#34;: {&#10;    &#34;company_number&#34;: string(get or else(companyRegistrationNumber, &#34;MOCK-00000000&#34;)),&#10;    &#34;company_name&#34;: string(get or else(registeredBusinessName, &#34;Demo Business Ltd&#34;)),&#10;    &#34;type&#34;: &#34;private-limited-company&#34;,&#10;    &#34;previous_company_names&#34;: [],&#10;    &#34;company_status&#34;: &#34;active&#34;,&#10;    &#34;date_of_creation&#34;: &#34;2020-01-01&#34;,&#10;    &#34;has_charges&#34;: false,&#10;    &#34;sic_codes&#34;: [&#34;62020&#34;],&#10;    &#34;registered_office_address&#34;: {&#10;      &#34;address_line_1&#34;: string(get or else(registeredOfficeAddress, &#34;1 Demo Street&#34;)),&#10;      &#34;address_line_2&#34;: &#34;&#34;,&#10;      &#34;locality&#34;: &#34;London&#34;,&#10;      &#34;region&#34;: &#34;&#34;,&#10;      &#34;postal_code&#34;: &#34;EC1A 1AA&#34;,&#10;      &#34;country&#34;: &#34;England&#34;&#10;    }&#10;  },&#10;  &#34;reason&#34;: &#34;DEMO MOCK: local active-company profile. Replace this Script Task with the Companies House connector for a live registry check.&#34;,&#10;  &#34;source&#34;: &#34;MOCK_COMPANIES_HOUSE&#34;&#10;}" resultVariable="companyHouseDetails" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1er4yqk</bpmn:incoming>
      <bpmn:outgoing>Flow_129t9vo</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0gl7yh5" name="completed for now" sourceRef="gateway_post_verification_needed" targetRef="Event_1dszvoa">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agent.responseJson.nextAction = "EXIT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0o6w8jy" sourceRef="Event_1y97jvp" targetRef="Activity_11w2qbj" />
    <bpmn:sequenceFlow id="Flow_0xs7gqs" sourceRef="Activity_0e1ermh" targetRef="gateway_initial_verification_outcome" />
    <bpmn:sequenceFlow id="Flow_129t9vo" sourceRef="Activity_0b2aj8s" targetRef="gateway_initial_verification_outcome" />
    <bpmn:sequenceFlow id="Flow_1ar89vw" sourceRef="gateway_begin_process_documents" targetRef="Activity_0e1ermh" />
    <bpmn:sequenceFlow id="Flow_1er4yqk" sourceRef="gateway_begin_process_documents" targetRef="Activity_0b2aj8s" />
    <bpmn:sequenceFlow id="Flow_1i0hqc6" sourceRef="gateway_initial_verification_outcome" targetRef="Activity_0tyru61" />
    <bpmn:exclusiveGateway id="gateway_post_verification_needed" name="Further action required?">
      <bpmn:incoming>Flow_11a0qag</bpmn:incoming>
      <bpmn:outgoing>Flow_0gl7yh5</bpmn:outgoing>
      <bpmn:outgoing>Flow_1colao6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="gateway_initial_verification_outcome" name="Initial verification checks complete">
      <bpmn:incoming>Flow_0xs7gqs</bpmn:incoming>
      <bpmn:incoming>Flow_129t9vo</bpmn:incoming>
      <bpmn:outgoing>Flow_1i0hqc6</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:parallelGateway id="gateway_begin_process_documents" name="Begin process documents received">
      <bpmn:incoming>Flow_182sqt7</bpmn:incoming>
      <bpmn:outgoing>Flow_1ar89vw</bpmn:outgoing>
      <bpmn:outgoing>Flow_1er4yqk</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_10s5gwg" name="Need&#10;Verification" sourceRef="gateway_verification_needed" targetRef="Agentic_loan_verification">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=verificationRoute in ["EXCEPTION", "PASSED"]</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:startEvent id="Event_1y97jvp" name="Start business loan application">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="camundaModeler:exampleOutputJson" value="{&#34;formFullName&#34;:&#34;Virgile Ygorra&#34;,&#34;formEmail&#34;:&#34;virgile.ygorra@camunda.com&#34;,&#34;formPhoneNumber&#34;:&#34;+33110101010&#34;,&#34;formVehicleVIN&#34;:&#34;WVWRA7CD1RW226165&#34;,&#34;formFuelEnergyType&#34;:&#34;gasoline&#34;,&#34;formRequestedLoanAmount&#34;:35000,&#34;quote&#34;:&#34;files::7kxjfqnxnq59f6pbnmn9otgtv&#34;,&#34;picture&#34;:&#34;files::4ymhzlfd8hs6urq0oxobxtrba&#34;}" />
        </zeebe:properties>
        <zeebe:formDefinition formId="start-onboarding-application-1tklzcw" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0o6w8jy</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="Agentic_loan_verification" name="AI AGENT - Handle Loan Application Verification" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="10" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="0" />
        <zeebe:ioMapping>
          <zeebe:input source="openai" target="provider.type" />
          <zeebe:input source="{{secrets.OPENAI_API_KEY}}" target="provider.openai.authentication.apiKey" />
          <zeebe:input source="gpt-5-nano" target="provider.openai.model.model" />
          <zeebe:input source="=&#34;DEMO INTEGRATION MODE — The Companies House, CRM/Salesforce, and email tasks marked [DEMO MOCK] do not call external systems. They generate local process results only: no registry lookup, CRM record, or email is real. Keep the same process sequence for the workshop. When live credentials are available, replace each marked Script Task with its documented connector while preserving its output-variable contract.&#34; + &#34;\n\n&#34; + &#34;You are BusinessLoanSupportAgent, the dedicated business-loan onboarding assistant for the bank named &#34; + string(companyName) + &#34;. Always check&#34; +approveOrRejectApplication + &#34; and&#34; +decisionRationale + &#34; before you call any tool to understand the next action and tool call You should call atleast one tool each iteration and appropriate tool and each tool only once if the email response recieved from user is unclear or incomplete and user has not provided consent and documents in response then go for manual review to the Loan specialist i.e. next agent action is ESCALATE_TO_LOAN_SPECIALIST &#34; +&#10;&#34;\n\n# 0. CONTEXT&#34; +&#10;&#34;\nThe user is a business-loan applicant whose application is under review.&#34; +&#10;&#34;\nA Salesforce Lead has already been created before this subprocess.&#34; +&#10;&#34;\nThe Lead ID is available as salesforceLeadId.&#34; +&#10;&#34;\nYour role is to assess the application, update this existing Lead, and send or request the correct next communication.&#34; +&#10;&#10;&#34;\n\n# 1. SCOPE&#34; +&#10;&#34;\nUse only the business-loan form, Companies House verification, company-proof analysis, applicant declarations, verificationRoute, and tool results supplied to you.&#34; +&#10;&#34;\nDetermine whether the applicant should receive a provisional offer, a request for more information, Loan Specialist review, or rejection.&#34; +&#10;&#34;\nThis is an onboarding and pre-decision workflow.&#34; +&#10;&#34;\nNever state that final legally binding loan approval has been granted.&#34; +&#10;&#34;\nAny offer must be described as provisional and subject to final bank approval.&#34; +&#10;&#34;\nDo not invent, infer, or assume missing information.&#34; +&#10;&#34;\nAll applicant-facing communication must be written in &#34; + string(language) + &#34;.&#34; +&#10;&#10;&#34;\n\n# 2. VERIFICATION ROUTE&#34; +&#10;&#34;\nverificationRoute is a deterministic pre-check result set before this agent runs.&#34; +&#10;&#34;\nPASSED means company status, company number, proof, consent, and declaration checks passed.&#34; +&#10;&#34;\nEXCEPTION means the case may be remediable, for example missing consent, missing declaration, unreadable proof, wrong proof type, insufficient proof, or unclear authority.&#34; +&#10;&#34;\nHARD_FAIL means Companies House status is not active or the Companies House company number does not match the submitted company registration number.&#34; +&#10;&#10;&#34;\n\n# 3. MANDATORY TOOL WORKFLOW&#34; +&#10;&#34;\n1. Inspect every available tool and assess its relevance.&#34; +&#10;&#34;\n2. Use only tools necessary to resolve the case safely.&#34; +&#10;&#34;\n3. Do not call a tool merely because it exists.&#34; +&#10;&#34;\n4. Before any applicant email or Loan Specialist escalation, update the existing Salesforce Lead using salesforceLeadId.&#34; +&#10;&#34;\n5. After each relevant tool result, reassess whether another tool is needed.&#34; +&#10;&#34;\n6. If a material issue cannot be safely resolved, use the Loan Specialist decision tool. Do not guess.&#34; +&#10;&#34;\n7. In thinking.reflection, list every available tool exactly once as USED, NOT USED, or WAITING with a concise operational reason.&#34; +&#10;&#34;\n8. thinking.reflection is an audit trail only. Do not reveal hidden reasoning or private deliberation.&#34; +&#10;&#10;&#34;\n\n# 3A. EXECUTION CONTRACT&#34; +&#10;&#34;\nDo not return a final JSON response while a mandatory operational action remains outstanding.&#34; +&#10;&#10;&#34;\nFor EXCEPTION where the applicant can correct the issue:&#34; +&#10;&#34;\n1. First call Update CRM lead [DEMO MOCK] with Status Contacted.&#34; +&#10;&#34;\n2. After its result, set the action as ASK_FOR_PROOFS_OR_QUESTIONS call Log clarification email [DEMO MOCK].&#34; +&#10;&#34;\n3. After that email is sent, do not return a final JSON response. The process must wait at Simulate applicant response [DEMO MOCK].&#34; +&#10;&#34;\n4. When Simulate applicant response [DEMO MOCK] supplies a tool result, reassess the application using the new evidence and set next action to ESCALATE_TO_LOAN_SPECIALIST to call loan specialist to review the decision.&#34; +&#10;&#10;&#34;\nFor HARD_FAIL:&#34; +&#10;&#34;\n1. First call Update CRM lead [DEMO MOCK] with Status Unqualified.&#34; +&#10;&#34;\n2. After its result, call Log final applicant email [DEMO MOCK] with the rejection decision.&#34; +&#10;&#34;\n3. Return final JSON only after the rejection email has been sent.&#34; +&#10;&#10;&#34;\nFor PASSED:&#34; +&#10;&#34;\n1. First call Get Credit Score.&#34; +&#10;&#34;\n2. If score is 600 or above with no authority issue, call Update CRM lead [DEMO MOCK] with Status Qualified, then call Log final applicant email [DEMO MOCK].&#34; +&#10;&#34;\n3. If score is below 600 or authority is unresolved, call Update CRM lead [DEMO MOCK] with Status Nurturing, then call Loan Specialist decision.&#34; +&#10;&#34;\n4. Return final JSON only after the required tool sequence is complete or the process is waiting at Loan Specialist decision.&#34; +&#10;&#10;&#34;\nA narrative JSON decision alone is not an action. For any actionable case, make the required tool call before returning JSON.&#10;\n\n# 4. SALESFORCE LEAD RULES&#34; +&#10;&#34;\nUse Update CRM lead [DEMO MOCK] for every outcome.&#34; +&#10;&#34;\nAlways update the existing Lead identified by salesforceLeadId.&#34; +&#10;&#34;\nNever create a second Lead in this subprocess.&#34; +&#10;&#34;\nThe Lead update tool can update only Status and Description.&#34; +&#10;&#34;\nUse these Salesforce Lead Status values exactly:&#34; +&#10;&#34;\nNew means verification in progress.&#34; +&#10;&#34;\nContacted means waiting for applicant consent, declaration, clarification, or replacement evidence.&#34; +&#10;&#34;\nNurturing means Loan Specialist or manual review.&#34; +&#10;&#34;\nQualified means provisional offer sent.&#34; +&#10;&#34;\nUnqualified means rejected.&#34; +&#10;&#34;\nDescription must contain a concise audit note with verification decision, reason, next action, Companies House outcome, proof outcome, credit score and risk band if available, and applicant actions required.&#34; +&#10;&#10;&#34;\n\n# 5. TOOL RULES&#34; +&#10;&#10;&#34;\n\nTOOL: Update CRM lead [DEMO MOCK]&#34; +&#10;&#34;\nUse before sending an offer, requesting information, rejecting, or escalating.&#34; +&#10;&#34;\nUpdate Status to Contacted before asking the applicant for evidence or clarification.&#34; +&#10;&#34;\nUpdate Status to Nurturing before Loan Specialist escalation.&#34; +&#10;&#34;\nUpdate Status to Qualified before sending a provisional offer.&#34; +&#10;&#34;\nUpdate Status to Unqualified before sending a rejection email.&#34; +&#10;&#10;&#34;\n\nTOOL: Get Credit Score&#34; +&#10;&#34;\nUse only when verificationRoute is PASSED and creditCheckConsent is true.&#34; +&#10;&#34;\nThis is a simulated demonstration score, not a real credit-bureau result.&#34; +&#10;&#34;\nScore 700 or above means LOW risk.&#34; +&#10;&#34;\nScore from 600 to 699 means STANDARD risk.&#34; +&#10;&#34;\nScore below 600 means ELEVATED risk and normally requires Loan Specialist review.&#34; +&#10;&#34;\nDo not reject solely because of the simulated score.&#34; +&#10;&#34;\nRecord the score and risk band in the Lead Description.&#34; +&#10;&#10;&#34;\n\nTOOL: Get company directors [DEMO MOCK]&#34; +&#10;&#34;\nUse only when applicant authority is relevant and unclear.&#34; +&#10;&#34;\nFor example, use it when the applicant claims to be a Director but authority cannot be established from the supplied evidence.&#34; +&#10;&#34;\nDo not use it when authority is already clear or irrelevant.&#34; +&#10;&#10;&#34;\n\nTOOL: Log clarification email [DEMO MOCK]&#34; +&#10;&#34;\nUse when the applicant can resolve the issue by providing consent, confirming a declaration, answering a question, replacing a document, uploading more proof, or clarifying their role.&#34; +&#10;&#34;\nAsk for the exact missing information or evidence. Do not send vague requests.&#34; +&#10;&#34;\nUpdate the Lead Status to Contacted before using this tool.&#34; +&#10;&#34;\nDo not ask the applicant to reconfirm information already verified by Companies House.&#34; +&#10;&#10;&#34;\n\nTOOL: Simulate applicant response [DEMO MOCK]&#34; +&#10;&#34;\nThis is an event and not a tool you actively call.&#34; +&#10;&#34;\nWhen a response or new evidence arrives, reassess the full case.&#34; +&#10;&#34;\nUpdate the Lead Status to New before the renewed assessment.&#34; +&#10;&#10;&#34;\n\nTOOL: Loan Specialist decision&#34; +&#10;&#34;\nUse this tool for unresolved material inconsistencies, unclear applicant authority, conflicting authoritative evidence, a simulated score below 600, or any issue requiring human banking judgement.&#34; +&#10;&#34;\nBefore escalation, update the existing Lead Status to Nurturing.&#34; +&#10;&#34;\nProvide a concise factual handover covering verification route, Companies House outcome, company-proof outcome, actions taken, outstanding issue, credit-risk band, and recommended outcome.&#34; +&#10;&#34;\nThe Loan Specialist response is authoritative.&#34; +&#10;&#34;\nThe returned response contains a decision, rationale, and optional information or evidence required.&#34; +&#10;&#34;\nAfter the Loan Specialist response:&#34; +&#10;&#34;\n- If decision is PROVISIONAL_OFFER, update the Lead Status to Qualified, add the rationale to Description, then send the provisional offer email.&#34; +&#10;&#34;\n- If decision is REQUEST_INFORMATION, update the Lead Status to Contacted, add the rationale and requested evidence to Description, then use Log clarification email [DEMO MOCK].&#34; +&#10;&#34;\n- If decision is REJECT, update the Lead Status to Unqualified, add the rationale to Description, then send the rejection email.&#34; +&#10;&#34;\nDo not override or reinterpret the Loan Specialist decision.&#34; +&#10;&#10;&#34;\n\nTOOL: Log final applicant email [DEMO MOCK]&#34; +&#10;&#34;\nUse only after the relevant Lead update is complete.&#34; +&#10;&#34;\nFor a satisfactory case, send a provisional offer email including requested loan amount, term, purpose, next steps, and the statement that final bank approval is still required.&#34; +&#10;&#34;\nFor a clarification case, do not use this tool. Use Log clarification email [DEMO MOCK].&#34; +&#10;&#34;\nFor rejection, send a concise respectful email without disclosing internal scores or hidden reasoning.&#34; +&#10;&#34;\nFor Manual Review, send only an acknowledgement that the application is under specialist review unless a final specialist decision is available.&#34; +&#10;&#10;&#34;\n\n# 6. DECISION RULES&#34; +&#10;&#10;&#34;\n\nHARD_FAIL&#34; +&#10;&#34;\nWhen verificationRoute is HARD_FAIL, do not call Get Credit Score.&#34; +&#10;&#34;\nUpdate the Lead Status to Unqualified.&#34; +&#10;&#34;\nSend the final rejection email.&#34; +&#10;&#34;\nUse verificationDecision REJECT.&#34; +&#10;&#34;\nUse nextAction SEND_REJECTION.&#34; +&#10;&#10;&#34;\n\nPASSED&#34; +&#10;&#34;\nWhen verificationRoute is PASSED, call Get Credit Score.&#34; +&#10;&#34;\nIf the simulated score is 600 or above and there is no unresolved authority issue, update the Lead Status to Qualified and send the provisional offer email.&#34; +&#10;&#34;\nUse verificationDecision PROVISIONAL_OFFER.&#34; +&#10;&#34;\nUse nextAction SEND_PROVISIONAL_OFFER.&#34; +&#10;&#34;\nIf the simulated score is below 600 or authority remains unclear, update the Lead Status to Nurturing and use the Loan Specialist decision tool.&#34; +&#10;&#34;\nFollow the returned specialist decision.&#34; +&#10;&#34;\nUse verificationDecision MANUAL_REVIEW while the specialist decision is pending.&#34; +&#10;&#34;\nUse nextAction ESCALATE_TO_LOAN_SPECIALIST while pending.&#34; +&#10;&#10;&#34;\n\nEXCEPTION&#34; +&#10;&#34;\nWhen verificationRoute is EXCEPTION, do not call Get Credit Score unless the verification issue is resolved and creditCheckConsent is true.&#34; +&#10;&#34;\nIf the applicant can reasonably correct the issue, update the Lead Status to Contacted and ask for the exact proof, declaration, consent, or clarification needed.&#34; +&#10;&#34;\nUse verificationDecision REQUEST_INFORMATION.&#34; +&#10;&#34;\nUse nextAction ASK_FOR_PROOFS_OR_QUESTIONS.&#34; +&#10;&#34;\nIf the issue is material and cannot safely be resolved automatically, update the Lead Status to Nurturing and use the Loan Specialist decision tool.&#34; +&#10;&#34;\nFollow the returned specialist decision.&#10;\nUse verificationDecision MANUAL_REVIEW while the specialist decision is pending.&#10;\nUse nextAction ESCALATE_TO_LOAN_SPECIALIST while pending.&#10;\nUse nextAction EXIT when no firther action is needed.\n\n# 7. OUTPUT FORMAT\nReturn valid JSON only. Do not return markdown or text outside the JSON object.\nReturn exactly these top-level fields:\nthinking \nverificationDecision \nnextAction \nloanApplicationStatus \ncreditScore \ncreditRiskBand \nreasonCodes \nverificationSummary \nrequiredActions \nconfidence \nthinking must contain context and reflection.\nverificationDecision must be PROVISIONAL_OFFER, REQUEST_INFORMATION, MANUAL_REVIEW, REJECT, or ERROR.\nnextAction must be GET_CREDIT_SCORE, CHECK_DIRECTORS, ASK_FOR_PROOFS_OR_QUESTIONS, ESCALATE_TO_LOAN_SPECIALIST, SEND_PROVISIONAL_OFFER, SEND_REJECTION, or WAIT_FOR_APPLICANT_RESPONSE.&#10;\nloanApplicationStatus must be one of New, Contacted, Nurturing, Qualified, or Unqualified.&#34; +&#10;&#34;\ncreditRiskBand must be NOT_CHECKED, LOW, STANDARD, or ELEVATED.&#34; +&#10;&#34;\nreasonCodes and requiredActions must be JSON arrays.&#34; +&#10;&#34;\ncreditScore must be 0 when Get Credit Score was not called.&#34; +&#10;&#34;\nconfidence must be a number from 0 to 1.&#10;\nNever describe a simulated credit score as a real credit-bureau result.&#34; +&#10;&#34;\nIf a technical blocker prevents resolution, use verificationDecision ERROR and state the factual blocker inside verificationSummary.&#34; +&#10;&#34;\nIf the case is unresolved without a technical failure, choose MANUAL_REVIEW rather than ERROR. Based on the next action use appropriate tool for example send email using Activity_115vchg if nextaction is ASK_FOR_PROOFS_OR_QUESTIONS&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Analyze this business-loan application using the information below.Always check&#34; +string(get or else(loanSpecialistDecision, &#34;&#34;)) + &#34; and&#34; +string(get or else(decisionRationale, &#34;&#34;)) + &#34; before you call any tool to understand the next action if analyst is happy dont send request for more tools isntead call final offer. After final offer or decline email no more tool calls next action is exit and tool call You should call atleast one tool each iteration and appropriate tool and each tool only once if the email response recieved from user is unclear or incomplete and user has not provided consent and documents in response then go for manual review to the Loan specialist i.e. next agent action is ESCALATE_TO_LOAN_SPECIALIST &#34; + &#34;\n\n# 0. CONTEXT&#34; + &#34;\nThe user is a business-loan applicant whose application is under review.&#34; + &#34;\nA Salesforce Lead has already been created before this subprocess.&#34; + &#34;\nThe Lead ID is available as salesforceLeadId.&#34; + &#34;\nYour role is to assess the application, update this existing Lead, and send or request the correct next communication.&#34;+&#10;&#10;&#34;\n\nEXISTING SALESFORCE LEAD&#34; +&#10;&#34;\nSalesforce Lead ID: &#34; + string(get or else(salesforceLeadId, &#34;&#34;)) +&#10;&#34;\nA Salesforce Lead already exists for this application.&#34; +&#10;&#34;\nUpdate this exact Lead only. Do not create another Lead.&#34; +&#10;&#10;&#34;\n\nPRE-CHECK ROUTE&#34; +&#10;&#34;\nVerification route: &#34; + string(get or else(verificationRoute, &#34;&#34;)) +&#10;&#34;\nPASSED means all deterministic company, proof, consent, and declaration checks passed.&#34; +&#10;&#34;\nEXCEPTION means the applicant may be able to correct missing, unclear, unreadable, incomplete, or mismatched evidence.&#34; +&#10;&#34;\nHARD_FAIL means the company is inactive or the Companies House company number does not match the submitted company registration number.&#34; +&#10;&#10;&#34;\n\nAPPLICATION DETAILS&#34; +&#10;&#34;\nRegistered business name: &#34; + string(get or else(registeredBusinessName, &#34;&#34;)) +&#10;&#34;\nCompany registration number: &#34; + string(get or else(companyRegistrationNumber, &#34;&#34;)) +&#10;&#34;\nBusiness type: &#34; + string(get or else(businessType, &#34;&#34;)) +&#10;&#34;\nRegistered office address: &#34; + string(get or else(registeredOfficeAddress, &#34;&#34;)) +&#10;&#34;\nTrading address: &#34; + string(get or else(tradingAddress, &#34;&#34;)) +&#10;&#34;\nBusiness website: &#34; + string(get or else(businessWebsite, &#34;&#34;)) +&#10;&#34;\nIndustry: &#34; + string(get or else(industry, &#34;&#34;)) +&#10;&#34;\nBusiness description: &#34; + string(get or else(businessDescription, &#34;&#34;)) +&#10;&#34;\nVAT number: &#34; + string(get or else(vatNumber, &#34;&#34;)) +&#10;&#10;&#34;\n\nLOAN REQUEST&#34; +&#10;&#34;\nRequested loan amount: &#34; + string(get or else(loanAmount, &#34;&#34;)) +&#10;&#34;\nLoan purpose: &#34; + string(get or else(loanPurpose, &#34;&#34;)) +&#10;&#34;\nLoan term in months: &#34; + string(get or else(loanTerm, &#34;&#34;)) +&#10;&#10;&#34;\n\nAPPLICANT DETAILS&#34; +&#10;&#34;\nApplicant full name: &#34; + string(get or else(applicantFullName, &#34;&#34;)) +&#10;&#34;\nApplicant position in business: &#34; + string(get or else(applicantPosition, &#34;&#34;)) +&#10;&#34;\nApplicant email: &#34; + string(get or else(applicantEmail, &#34;&#34;)) +&#10;&#34;\nApplicant phone: &#34; + string(get or else(applicantPhone, &#34;&#34;)) +&#10;&#34;\nCredit-check consent: &#34; + string(get or else(creditCheckConsent, false)) +&#10;&#34;\nInformation accuracy declaration: &#34; + string(get or else(informationAccuracyDeclaration, false)) +&#10;&#10;&#34;\n\nCOMPANIES HOUSE VERIFICATION&#34; +&#10;&#34;\nCompanies House company name: &#34; + string(get or else(companyHouseDetails.body.company_name, &#34;&#34;)) +&#10;&#34;\nCompanies House company number: &#34; + string(get or else(companyHouseDetails.body.company_number, &#34;&#34;)) +&#10;&#34;\nCompanies House company status: &#34; + string(get or else(companyHouseDetails.body.company_status, &#34;&#34;)) +&#10;&#34;\nDate of incorporation: &#34; + string(get or else(companyHouseDetails.body.date_of_creation, &#34;&#34;)) +&#10;&#34;\nCompany type: &#34; + string(get or else(companyHouseDetails.body.type, &#34;&#34;)) +&#10;&#34;\nCompanies House registered office: &#34; +&#10;string join([&#10;string(get or else(companyHouseDetails.body.registered_office_address.address_line_1, &#34;&#34;)),&#10;string(get or else(companyHouseDetails.body.registered_office_address.address_line_2, &#34;&#34;)),&#10;string(get or else(companyHouseDetails.body.registered_office_address.locality, &#34;&#34;)),&#10;string(get or else(companyHouseDetails.body.registered_office_address.region, &#34;&#34;)),&#10;string(get or else(companyHouseDetails.body.registered_office_address.postal_code, &#34;&#34;)),&#10;string(get or else(companyHouseDetails.body.registered_office_address.country, &#34;&#34;))&#10;], &#34;, &#34;) +&#10;&#34;\nPrevious company-name records found: &#34; +&#10;string(count(get or else(companyHouseDetails.body.previous_company_names, []))) +&#10;&#34;\nCompanies House result reason: &#34; + string(get or else(companyHouseDetails.reason, &#34;&#34;)) +&#10;&#10;&#34;\n\nCOMPANY-PROOF VERIFICATION&#34; +&#10;&#34;\nApplicant-selected proof type: &#34; + string(get or else(companyProofType, &#34;&#34;)) +&#10;&#34;\nDocument readable: &#34; + string(get or else(companyProofAnalyzedByAI.document_readable, false)) +&#10;&#34;\nDetected document type: &#34; + string(get or else(companyProofAnalyzedByAI.document_type_detected, &#34;&#34;)) +&#10;&#34;\nDocument type matches selected type: &#34; + string(get or else(companyProofAnalyzedByAI.document_type_matches_selection, false)) +&#10;&#34;\nExtracted company name: &#34; + string(get or else(companyProofAnalyzedByAI.company_name_extracted, &#34;&#34;)) +&#10;&#34;\nExtracted company number: &#34; + string(get or else(companyProofAnalyzedByAI.company_number_extracted, &#34;&#34;)) +&#10;&#34;\nExtracted document date: &#34; + string(get or else(companyProofAnalyzedByAI.document_date_extracted, &#34;&#34;)) +&#10;&#34;\nCompany name match: &#34; + string(get or else(companyProofAnalyzedByAI.company_name_match, false)) +&#10;&#34;\nCompany number match: &#34; + string(get or else(companyProofAnalyzedByAI.company_number_match, false)) +&#10;&#34;\nRegistered address match: &#34; + string(get or else(companyProofAnalyzedByAI.registered_address_match, false)) +&#10;&#34;\nTrading address match: &#34; + string(get or else(companyProofAnalyzedByAI.trading_address_match, false)) +&#10;&#34;\nDocument recent enough: &#34; + string(get or else(companyProofAnalyzedByAI.document_recent_enough, false)) +&#10;&#34;\nEvidence outcome: &#34; + string(get or else(companyProofAnalyzedByAI.evidence_outcome, &#34;&#34;)) +&#10;&#34;\nEvidence discrepancies supplied: &#34; +&#10;(if companyProofAnalyzedByAI.discrepancies = null then &#34;No&#34; else &#34;Yes&#34;) +&#10;&#34;\nMissing or unreadable fields supplied: &#34; +&#10;(if companyProofAnalyzedByAI.missing_or_unreadable_fields = null then &#34;No&#34; else &#34;Yes&#34;) +&#10;&#34;\nEvidence summary: &#34; + string(get or else(companyProofAnalyzedByAI.summary, &#34;&#34;)) +&#10;&#10;&#34;\n\nPROCESS INSTRUCTIONS&#34; +&#10;&#34;\nUse verificationRoute together with the Companies House and company-proof results.&#34; +&#10;&#10;&#34;\n\nFor HARD_FAIL:&#34; +&#10;&#34;\nDo not call Get Credit Score.&#34; +&#10;&#34;\nUpdate the existing Lead to Unqualified.&#34; +&#10;&#34;\nSend the rejection email.&#34; +&#10;&#10;&#34;\n\nFor PASSED:&#34; +&#10;&#34;\nCall Get Credit Score because credit-check consent is confirmed.&#34; +&#10;&#34;\nIf score is 600 or above and there is no unresolved authority issue, update the Lead to Qualified and send a provisional offer.&#34; +&#10;&#34;\nIf score is below 600 or authority remains unclear, update the Lead to Nurturing and use Loan Specialist decision.&#34; +&#10;&#10;&#34;\n\nFor EXCEPTION:&#34; +&#10;&#34;\nDo not call Get Credit Score unless the verification issue is resolved and consent is true.&#34; +&#10;&#34;\nIdentify the exact missing proof, consent, declaration, clarification, or authority check required.&#34; +&#10;&#34;\nUpdate the Lead to Contacted before asking the applicant for information.&#34; +&#10;&#34;\nUse Nurturing and Loan Specialist decision only where the issue cannot safely be resolved automatically.&#34; +&#10;&#10;&#34;\nUse the existing Salesforce Lead ID above for every Lead update.&#34;&#10;" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=20" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="json" target="data.response.format.type" />
          <zeebe:input source="={&#10;  &#34;type&#34;: &#34;object&#34;,&#10;  &#34;properties&#34;: {&#10;    &#34;thinking&#34;: {&#10;      &#34;type&#34;: &#34;object&#34;,&#10;      &#34;properties&#34;: {&#10;        &#34;context&#34;: {&#10;          &#34;type&#34;: &#34;string&#34;&#10;        },&#10;        &#34;reflection&#34;: {&#10;          &#34;type&#34;: &#34;string&#34;&#10;        }&#10;      },&#10;      &#34;required&#34;: [&#10;        &#34;context&#34;,&#10;        &#34;reflection&#34;&#10;      ]&#10;    },&#10;    &#34;verificationDecision&#34;: {&#10;      &#34;type&#34;: &#34;string&#34;,&#10;      &#34;enum&#34;: [&#10;        &#34;PROVISIONAL_OFFER&#34;,&#10;        &#34;REQUEST_INFORMATION&#34;,&#10;        &#34;MANUAL_REVIEW&#34;,&#10;        &#34;REJECT&#34;,&#10;        &#34;ERROR&#34;&#10;      ]&#10;    },&#10;    &#34;nextAction&#34;: {&#10;&#34;type&#34;: &#34;string&#34;,&#10;&#34;enum&#34;: [&#10;&#34;GET_CREDIT_SCORE&#34;,&#10;&#34;CHECK_DIRECTORS&#34;,&#10;&#34;ASK_FOR_PROOFS_OR_QUESTIONS&#34;,&#10;&#34;ESCALATE_TO_LOAN_SPECIALIST&#34;,&#10;&#34;SEND_PROVISIONAL_OFFER&#34;,&#10;&#34;SEND_REJECTION&#34;,&#10;&#34;WAIT_FOR_APPLICANT_RESPONSE&#34;,&#10;  &#34;EXIT&#34;&#10;]&#10;}&#10;,&#10;    &#34;loanApplicationStatus&#34;: {&#10;      &#34;type&#34;: &#34;string&#34;,&#10;      &#34;enum&#34;: [&#10;        &#34;New&#34;,&#10;&#34;Contacted&#34;,&#10;&#34;Nurturing&#34;,&#10;&#34;Qualified&#34;,&#10;&#34;Unqualifide&#34;&#10;      ]&#10;    },&#10;    &#34;creditScore&#34;: {&#10;      &#34;type&#34;: &#34;number&#34;&#10;    },&#10;    &#34;creditRiskBand&#34;: {&#10;      &#34;type&#34;: &#34;string&#34;,&#10;      &#34;enum&#34;: [&#10;        &#34;NOT_CHECKED&#34;,&#10;        &#34;LOW&#34;,&#10;        &#34;STANDARD&#34;,&#10;        &#34;ELEVATED&#34;&#10;      ]&#10;    },&#10;    &#34;reasonCodes&#34;: {&#10;      &#34;type&#34;: &#34;array&#34;,&#10;      &#34;items&#34;: {&#10;        &#34;type&#34;: &#34;string&#34;&#10;      }&#10;    },&#10;    &#34;verificationSummary&#34;: {&#10;      &#34;type&#34;: &#34;string&#34;&#10;    },&#10;    &#34;requiredActions&#34;: {&#10;      &#34;type&#34;: &#34;array&#34;,&#10;      &#34;items&#34;: {&#10;        &#34;type&#34;: &#34;string&#34;&#10;      }&#10;    },&#10;    &#34;confidence&#34;: {&#10;      &#34;type&#34;: &#34;number&#34;&#10;    }&#10;  },&#10;  &#34;required&#34;: [&#10;    &#34;thinking&#34;,&#10;    &#34;verificationDecision&#34;,&#10;    &#34;nextAction&#34;,&#10;    &#34;loanApplicationStatus&#34;,&#10;    &#34;creditScore&#34;,&#10;    &#34;creditRiskBand&#34;,&#10;    &#34;reasonCodes&#34;,&#10;    &#34;verificationSummary&#34;,&#10;    &#34;requiredActions&#34;,&#10;    &#34;confidence&#34;&#10;  ]&#10;}" target="data.response.format.schema" />
          <zeebe:input source="BusinessLoanDecision" target="data.response.format.schemaName" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:input target="agent" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="10" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_10s5gwg</bpmn:incoming>
      <bpmn:outgoing>Flow_11a0qag</bpmn:outgoing>
      <bpmn:sequenceFlow id="Flow_0wd4cc5" sourceRef="ASK_FOR_PROOFS_OR_QUESTIONS" targetRef="Event_Applicant_Response_Received" />
      <bpmn:scriptTask id="Event_Applicant_Response_Received" name="Simulate applicant response [DEMO MOCK]">
        <bpmn:documentation>DEMO MOCK — replaces the inbound IMAP email listener so the exception path can run without a mailbox, SMTP, or IMAP setup.

Immediately produces a sample applicant response. The existing Review Customer Response step remains unchanged and lets the participant choose the appropriate next outcome.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the original inbound email/message catch event and configure the IMAP connector, correlation key, and response mapping.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;from&#34;: string(get or else(applicantEmail, &#34;[email not supplied]&#34;)),&#10;  &#34;subject&#34;: &#34;RE: business loan application&#34;,&#10;  &#34;body&#34;: &#34;DEMO APPLICANT RESPONSE: I will provide the requested information through the secure application journey.&#34;,&#10;  &#34;source&#34;: &#34;DEMO_MOCK_EMAIL&#34;,&#10;  &#34;received&#34;: true&#10;}" resultVariable="responseEmail" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0wd4cc5</bpmn:incoming>
        <bpmn:outgoing>Flow_04ncd1z</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="ASK_FOR_PROOFS_OR_QUESTIONS" name="Log clarification email [DEMO MOCK]">
        <bpmn:documentation>DEMO MOCK — no SMTP server is contacted and no email is sent.

Creates a local email log, including `emailSubject` and `emailBody`, so the participant can inspect what would have been sent and continue the existing applicant-response flow.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the SMTP Email connector. Preserve `emailBody` because the existing Review Customer Response task displays it.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;to&#34;: string(get or else(applicantEmail, &#34;[email not supplied]&#34;)),&#10;  &#34;subject&#34;: &#34;Action required: business loan application&#34;,&#10;  &#34;body&#34;: &#34;DEMO EMAIL LOGGED ONLY — no email was sent. We need additional information, clarification, consent, or replacement evidence for your business-loan application. Intended recipient: &#34; + string(get or else(applicantEmail, &#34;[email not supplied]&#34;)) + &#34;.&#34;,&#10;  &#34;deliveryStatus&#34;: &#34;NOT_SENT_DEMO_MODE&#34;,&#10;  &#34;provider&#34;: &#34;DEMO_MOCK_EMAIL&#34;&#10;}" resultVariable="mockClarificationEmail" />
          <zeebe:ioMapping>
            <zeebe:output source="=mockClarificationEmail.subject" target="emailSubject" />
            <zeebe:output source="=mockClarificationEmail.body" target="emailBody" />
            <zeebe:output source="=mockClarificationEmail" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0wd4cc5</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:intermediateThrowEvent id="Event_ResponseCorrelated" name="Response correlated">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=responseEmail" target="toolCallResult" />
            <zeebe:output source="=&#34;ESCALATE_TO_LOAN_SPECIALIST&#34;" target="agent.responseJson.nextAction" />
            <zeebe:output source="=responseEmail" target="emailSent" />
            <zeebe:output source="=responseEmail" target="customerResponse" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_04ncd1z</bpmn:incoming>
        <bpmn:outgoing>Flow_1uvtrsp</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_04ncd1z" sourceRef="Event_Applicant_Response_Received" targetRef="Event_ResponseCorrelated" />
      <bpmn:scriptTask id="Activity_ConfirmationEmail" name="Log final applicant email [DEMO MOCK]">
        <bpmn:documentation>DEMO MOCK — no SMTP server is contacted and no email is sent.

Creates a local email log for a provisional offer, manual-review acknowledgement, or rejection. The decision path remains exactly the same; only the delivery channel is mocked.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the SMTP Email connector and map the target recipient, subject, and body from the same process variables.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;to&#34;: string(get or else(applicantEmail, &#34;[email not supplied]&#34;)),&#10;  &#34;subject&#34;: if verificationRoute = &#34;HARD_FAIL&#34; or get or else(loanSpecialistDecision, &#34;&#34;) = &#34;REJECT&#34;&#10;             then &#34;Business loan application decision&#34;&#10;             else if get or else(loanSpecialistDecision, &#34;&#34;) = &#34;REQUEST_INFORMATION&#34;&#10;             then &#34;Action required: business loan application&#34;&#10;             else &#34;Provisional business loan offer&#34;,&#10;  &#34;body&#34;: &#34;DEMO EMAIL LOGGED ONLY — no email was sent. This task represents the final applicant communication. Intended recipient: &#34; + string(get or else(applicantEmail, &#34;[email not supplied]&#34;)) + &#34;.&#34;,&#10;  &#34;deliveryStatus&#34;: &#34;NOT_SENT_DEMO_MODE&#34;,&#10;  &#34;provider&#34;: &#34;DEMO_MOCK_EMAIL&#34;&#10;}" resultVariable="mockFinalEmail" />
          <zeebe:ioMapping>
            <zeebe:output source="=mockFinalEmail.subject" target="emailSubject" />
            <zeebe:output source="=mockFinalEmail.body" target="emailBody" />
            <zeebe:output source="=mockFinalEmail" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:userTask id="ESCALATE_TO_LOAN_SPECIALIST" name="Loan Specialist decision">
        <bpmn:documentation>Use when next agent action is ESCALATE_TO_LOAN_SPECIALIST or when a business-loan application needs human judgement or the user requires to speak to relationship manager or someone from bank or when email log (demo mock) response recieved has no concrete next action or user wants to cancel the application or says they contected the manger or are unsure.

Use for unresolved material inconsistencies, unclear applicant authority, conflicting authoritative evidence, or a simulated credit score below 600.

The Loan Specialist reviews the AI handover and selects one of three outcomes:

* Approve the application
* REQUEST_INFORMATION
* REJECT

The returned decision is authoritative. The AI Agent must update the existing CRM Lead (demo mock) and send the corresponding applicant communication.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(&#10;  toolCall.summaryOfAIAgent,&#10;  &#34;Write a concise factual handover for the Loan Specialist. Include verification route, Companies House outcome, company-proof outcome, applicant authority issue if any, simulated credit score and risk band if available, actions already taken, outstanding issue, and recommended decision. Return plain text only.Also take the context from previous actions taken&#34; &#10;)" target="summaryByAI" />
            <zeebe:output source="=&#34;Loan Specialist decision: &#34; + approveOrRejectApplication +&#10;&#34;\nDecision rationale: &#34; + specialistDecisionRationale +&#10;&#34;\nInformation or evidence required: &#34; +&#10;(if specialistRequestDetails = null or specialistRequestDetails = &#34;&#34; then &#34;[none]&#34; else specialistRequestDetails)" target="toolCallResult" />
            <zeebe:output source="=approveOrRejectApplication" target="loanSpecialistDecision" />
            <zeebe:output source="=specialistDecisionRationale" target="decisionRationale" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="loan-specialist-decision-1rpm541" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:intermediateThrowEvent id="Event_05tlg2w" name="Salesforce&#10;Updated">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=&#34;Salesforce Lead updated successfully&#34;" target="toolCalLResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0882nlv</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_0882nlv" sourceRef="UpdateSalesforceBusinessLoanApplication" targetRef="Event_05tlg2w" />
      <bpmn:scriptTask id="UpdateSalesforceBusinessLoanApplication" name="Update CRM lead [DEMO MOCK]">
        <bpmn:documentation>DEMO MOCK — no Salesforce or CRM call is made.

Logs a local completion result for the existing demo CRM Lead. It preserves the agent’s action sequence: update the CRM Lead before an applicant communication or escalation.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the Salesforce Update Lead connector. Use `salesforceLeadId` as the Lead ID and retain the `Status` and `Description` mapping described in the original implementation.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;recordId&#34;: string(get or else(salesforceLeadId, &#34;MOCK-LEAD-UNKNOWN&#34;)),&#10;  &#34;status&#34;: if verificationRoute = &#34;HARD_FAIL&#34; or get or else(loanSpecialistDecision, &#34;&#34;) = &#34;REJECT&#34; then &#34;Unqualified&#34;&#10;            else if verificationRoute = &#34;EXCEPTION&#34; or get or else(loanSpecialistDecision, &#34;&#34;) = &#34;REQUEST_INFORMATION&#34; then &#34;Contacted&#34;&#10;            else if get or else(loanSpecialistDecision, &#34;&#34;) = &#34;PROVISIONAL_OFFER&#34; then &#34;Qualified&#34;&#10;            else &#34;Nurturing&#34;,&#10;  &#34;description&#34;: &#34;DEMO MOCK: CRM update captured locally. No external CRM record was changed.&#34;,&#10;  &#34;provider&#34;: &#34;DEMO_MOCK_CRM&#34;,&#10;  &#34;message&#34;: &#34;DEMO MOCK: CRM Lead update completed locally.&#34;&#10;}" resultVariable="mockCrmUpdateResult" />
          <zeebe:ioMapping>
            <zeebe:output source="=mockCrmUpdateResult" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0882nlv</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="CHECK_DIRECTORS" name="Get company directors [DEMO MOCK]">
        <bpmn:documentation>DEMO MOCK — no Companies House API call is made.

Returns a synthetic director/officer response for workshop purposes. The mock assumes the named applicant can be treated as a Director unless the human reviewer chooses otherwise.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the Companies House officers/directors connector and preserve the resulting officer-list data available to the AI Agent.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;items&#34;: [&#10;    {&#10;      &#34;name&#34;: string(get or else(applicantFullName, &#34;Demo Applicant&#34;)),&#10;      &#34;officer_role&#34;: &#34;director&#34;,&#10;      &#34;appointed_on&#34;: &#34;2020-01-01&#34;&#10;    }&#10;  ],&#10;  &#34;total_results&#34;: 1,&#10;  &#34;company_number&#34;: string(get or else(companyRegistrationNumber, &#34;MOCK-00000000&#34;)),&#10;  &#34;source&#34;: &#34;MOCK_COMPANIES_HOUSE&#34;,&#10;  &#34;message&#34;: &#34;DEMO MOCK: applicant returned as an active company director.&#34;&#10;}" resultVariable="companyDirectorsDetails" />
          <zeebe:ioMapping>
            <zeebe:output source="=companyDirectorsDetails" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="GET_CREDIT_SCORE" name="Get Credit Score">
        <bpmn:documentation>Use only when verificationRoute is PASSED and creditCheckConsent is true and next action is GET_CREDIT_SCORE

Returns a simulated demonstration credit score for this business-loan application. The result contains score and source.

Do not use for HARD_FAIL or unresolved verification exceptions. A score below 600 requires Loan Specialist review; it must not cause automatic rejection.

The simulated result is also returned to the AI Agent as `toolCallResult`.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=if creditCheckConsent = true&#10;then {&#10;  &#34;score&#34;: floor(500 + random number() * 351),&#10;  &#34;source&#34;: &#34;SIMULATED_DEMO_SCORE&#34;&#10;}&#10;else {&#10;  &#34;score&#34;: null,&#10;  &#34;source&#34;: &#34;NOT_RUN_NO_CONSENT&#34;&#10;}" resultVariable="creditScoreResult" />
          <zeebe:ioMapping>
            <zeebe:output source="=creditScoreResult" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:userTask id="Activity_0y8bbnz" name="Review Customer Response">
        <bpmn:documentation>Use when next agent action is ESCALATE_TO_LOAN_SPECIALIST or when a business-loan application needs human judgement or the user requires to speak to relationship manager or someone from bank or when email log (demo mock) response recieved has no concrete next action or user wants to cancel the application or says they contected the manger or are unsure.

Use for unresolved material inconsistencies, unclear applicant authority, conflicting authoritative evidence, or a simulated credit score below 600.

The Loan Specialist reviews the AI handover and selects one of three outcomes:

* Approve the application
* REQUEST_INFORMATION
* REJECT

The returned decision is authoritative. The AI Agent must update the existing CRM Lead (demo mock) and send the corresponding applicant communication.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=emailBody" target="emailSent" />
            <zeebe:input source="=customerResponse" target="customerResponse" />
            <zeebe:output source="=&#34;Loan Specialist decision: &#34; + approveOrRejectApplication +&#10;&#34;\nDecision rationale: &#34; + specialistDecisionRationale +&#10;&#34;\nInformation or evidence required: &#34; +&#10;(if specialistRequestDetails = null or specialistRequestDetails = &#34;&#34; then &#34;[none]&#34; else specialistRequestDetails)" target="toolCallResult" />
            <zeebe:output source="=approveOrRejectApplication" target="loanSpecialistDecision" />
            <zeebe:output source="=specialistDecisionRationale" target="decisionRationale" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="Form_kvacyz4" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1uvtrsp</bpmn:incoming>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_1uvtrsp" sourceRef="Event_ResponseCorrelated" targetRef="Activity_0y8bbnz" />
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_11a0qag" sourceRef="Agentic_loan_verification" targetRef="gateway_post_verification_needed" />
    <bpmn:exclusiveGateway id="Gateway_00ldj35" name="Initial verification outcome?">
      <bpmn:incoming>Flow_1itfgc8</bpmn:incoming>
      <bpmn:outgoing>Flow_1rpzhyv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1rpzhyv" sourceRef="Gateway_00ldj35" targetRef="gateway_verification_needed" />
    <bpmn:scriptTask id="Activity_11w2qbj" name="Create CRM record [DEMO MOCK]">
      <bpmn:documentation>DEMO MOCK — no Salesforce or CRM call is made.

Creates a local demo CRM record identifier and exposes `salesforceLeadId` exactly as the downstream AI-agent subprocess expects. No external record is created.

TO ENABLE THE LIVE INTEGRATION: replace this Script Task with the Salesforce Create Lead connector. Keep the downstream output contract: `salesforceLeadId` must contain the created Lead ID.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  &#34;salesforceLeadId&#34;: &#34;MOCK-LEAD-&#34; + string(get or else(companyRegistrationNumber, &#34;00000000&#34;)),&#10;  &#34;salesforceProspectCreated&#34;: true,&#10;  &#34;status&#34;: &#34;New&#34;,&#10;  &#34;provider&#34;: &#34;DEMO_MOCK_CRM&#34;,&#10;  &#34;message&#34;: &#34;DEMO MOCK: CRM Lead created locally. No Salesforce record was created.&#34;&#10;}" resultVariable="createSalesforceProspectResult" />
        <zeebe:ioMapping>
          <zeebe:output source="=createSalesforceProspectResult.salesforceLeadId" target="salesforceLeadId" />
          <zeebe:output source="=createSalesforceProspectResult.salesforceProspectCreated" target="salesforceProspectCreated" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0o6w8jy</bpmn:incoming>
      <bpmn:outgoing>Flow_11l4de7</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_0tyru61" name="Set verification route">
      <bpmn:extensionElements>
        <zeebe:script expression="=if companyHouseDetails.body.company_status != &#34;active&#34;&#10;   or companyHouseDetails.body.company_number != string(companyRegistrationNumber)&#10;then &#34;HARD_FAIL&#34;&#10;else if companyProofAnalyzedByAI.document_readable = true&#10;   and companyProofAnalyzedByAI.document_type_matches_selection = true&#10;   and companyProofAnalyzedByAI.company_number_match = true&#10;   and companyProofAnalyzedByAI.evidence_outcome = &#34;PASS&#34;&#10;   and creditCheckConsent = true&#10;   and informationAccuracyDeclaration = true&#10;then &#34;PASSED&#34;&#10;else &#34;EXCEPTION&#34;" resultVariable="verificationRoute" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1i0hqc6</bpmn:incoming>
      <bpmn:outgoing>Flow_1itfgc8</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1itfgc8" sourceRef="Activity_0tyru61" targetRef="Gateway_00ldj35" />
    <bpmn:sequenceFlow id="Flow_1colao6" sourceRef="gateway_post_verification_needed" targetRef="gateway_verification_needed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agent.responseJson.nextAction != "EXIT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:boundaryEvent id="duplicate_id" name="Existing CRM Lead found" attachedToRef="Activity_11w2qbj">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=salesforceLeadId" target="salesforceLeadId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0o5gnbw</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1fioouj" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_0t5d2gr">
      <bpmn:incoming>Flow_0o5gnbw</bpmn:incoming>
      <bpmn:incoming>Flow_11l4de7</bpmn:incoming>
      <bpmn:outgoing>Flow_182sqt7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
